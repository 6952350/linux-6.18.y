/dts-v1/;

/* 必须包含音频和时钟的头文件，否则无法识别 AIU 等常量 */
#include <dt-bindings/sound/meson-aiu.h>
#include <dt-bindings/clock/gxbb-clkc.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/* 包含基础板级定义 */
#include "meson-gxl-s905w-p281.dts"

/ {
	compatible = "amlogic,m302a", "amlogic,s905w", "amlogic,meson-gxl";
	model = "Amlogic Meson GXL (S905L3b) MBH-M302A Box";

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	/* CVBS 视频连接器 */
	cvbs-connector {
		compatible = "composite-video-connector";
		port {
			cvbs_connector_in: endpoint {
				remote-endpoint = <&cvbs_vdac_out>;
			};
		};
	};

	/* 音频路由：将声音导向模拟 DAC (ACODEC) */
	sound {
		compatible = "amlogic,gx-sound-card";
		model = "M302A-AUDIO";
		
		audio-routing =
			"AU2 INL", "ACODEC LOLN",
			"AU2 INR", "ACODEC LORN";

		assigned-clocks = <&clkc CLKID_MPLL0>,
				  <&clkc CLKID_MPLL1>,
				  <&clkc CLKID_MPLL2>;
		assigned-clock-parents = <0>, <0>, <0>;
		assigned-clock-rates = <294912000>,
				       <270950400>,
				       <393216000>;

		dai-link-0 {
			sound-dai = <&aiu AIU_CPU CPU_I2S_FIFO>;
		};

		dai-link-1 {
			sound-dai = <&aiu AIU_CPU CPU_I2S_ENCODER>;
			dai-format = "i2s";
			mclk-fs = <256>;

			codec-0 {
				sound-dai = <&aiu AIU_HDMI_CTRL 0>;
			};

			codec-1 {
				sound-dai = <&aiu AIU_ACODEC_CTRL 0>;
			};
		};

		dai-link-2 {
			sound-dai = <&aiu AIU_HDMI_CTRL 1>;
		};

		dai-link-3 {
			sound-dai = <&aiu AIU_ACODEC_CTRL 1>;
		};
	};
};

/* 视频输出连接 */
&cvbs_vdac_port {
	cvbs_vdac_out: endpoint {
		remote-endpoint = <&cvbs_connector_in>;
	};
};

/* 启用音频子系统 */
&aiu {
	status = "okay";
};

/* 启用内部模拟音频编解码器 */
&acodec {
	status = "okay";
};

/* 网络修正：限制为百兆 */
&internal_phy {
	max-speed = <100>;
};

&ethmac {
	status = "okay";
};

/* GPU 核心修正 */
&mali {
	interrupts = <GIC_SPI 160 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 161 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 162 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH>,
		     <GIC_SPI 167 IRQ_TYPE_LEVEL_HIGH>;
	interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
};

/* eMMC 配置 */
&sd_emmc_c {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
};
