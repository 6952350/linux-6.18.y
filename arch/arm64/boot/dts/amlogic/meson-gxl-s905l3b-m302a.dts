/dts-v1/;

/* 1. 包含基础 P281 定义 */
#include "meson-gxl-s905w-p281.dts"

/ {
	compatible = "amlogic,m302a", "amlogic,s905w", "amlogic,meson-gxl";
	model = "Amlogic Meson GXL (S905L3b) MBH-M302A Box";

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	/* 定义 AV 物理接口连接器 */
	cvbs_connector: cvbs-connector {
		compatible = "composite-video-connector";
		port {
			cvbs_connector_in: endpoint {
				remote-endpoint = <&cvbs_vdac_out>;
			};
		};
	};
};

/* 2. 视频：通过端口路径连接 VDAC，不使用 Label 避免报错 */
&cvbs_vdac_port {
	cvbs_vdac_out: endpoint {
		remote-endpoint = <&cvbs_connector_in>;
	};
};

/* 3. 音频核心修正：使用路径注入，保护 HDMI 不丢失 */
&{/sound} {
	status = "okay";
	/* 必须同时包含 ACODEC(AV) 和 HDMI 的路由 */
	audio-routing =
		"AU2 INL", "ACODEC LOLN",
		"AU2 INR", "ACODEC LORN",
		"HDMI INL", "HDMI",
		"HDMI INR", "HDMI";
};

/* 4. 链路注入：在 I2S 传输链中追加模拟输出端 */
&{/sound/dai-link-1} {
	codec-1 {
		/* 使用数字索引避开头文件依赖：2=ACODEC_CTRL, 0=通道0 */
		sound-dai = <&aiu 2 0>;
	};
};

/* 5. 强制启用音频硬件模块 */
&aiu {
	status = "okay";
};

&acodec {
	status = "okay";
};

/* 6. GPU 修正：适配 S905L3b (仅 2 个 PP 核心) */
&mali {
	interrupts = <0 160 4>, <0 161 4>, <0 162 4>, <0 163 4>,
		     <0 164 4>, <0 165 4>, <0 166 4>, <0 167 4>;
	interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
};

/* 7. 网络与存储限制 */
&internal_phy {
	max-speed = <100>;
};

&ethmac {
	status = "okay";
};

&sd_emmc_c {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
};
