/dts-v1/;

/* 包含基础定义 */
#include "meson-gxl-s905w-p281.dts"

/* * 手动定义常量，防止 Lexical error 
 * 这些值参考自内核 dt-bindings/sound/meson-aiu.h
 */
#define AIU_CPU 0
#define AIU_HDMI_CTRL 1
#define AIU_ACODEC_CTRL 2
#define CPU_I2S_FIFO 1
#define CPU_I2S_ENCODER 1

/ {
	compatible = "amlogic,m302a", "amlogic,s905w", "amlogic,meson-gxl";
	model = "Amlogic Meson GXL (S905L3b) MBH-M302A Box";

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	/* CVBS 视频接口连接器 */
	cvbs-connector {
		compatible = "composite-video-connector";
		port {
			cvbs_connector_in: endpoint {
				remote-endpoint = <&cvbs_vdac_out>;
			};
		};
	};

	/* 音频卡配置：确保音频流向模拟 DAC */
	sound {
		compatible = "amlogic,gx-sound-card";
		model = "M302A-AUDIO";
		
		audio-routing =
			"AU2 INL", "ACODEC LOLN",
			"AU2 INR", "ACODEC LORN";

		/* 使用特定的 MPLL 时钟频率以支持音频采样率 */
		assigned-clocks = <&clkc 1>,  /* CLKID_MPLL0 */
				  <&clkc 2>,  /* CLKID_MPLL1 */
				  <&clkc 3>;  /* CLKID_MPLL2 */
		assigned-clock-parents = <0>, <0>, <0>;
		assigned-clock-rates = <294912000>,
				       <270950400>,
				       <393216000>;

		dai-link-0 {
			sound-dai = <&aiu AIU_CPU CPU_I2S_FIFO>;
		};

		dai-link-1 {
			sound-dai = <&aiu AIU_CPU CPU_I2S_ENCODER>;
			dai-format = "i2s";
			mclk-fs = <256>;

			codec-0 {
				sound-dai = <&aiu AIU_HDMI_CTRL 0>;
			};

			codec-1 {
				sound-dai = <&aiu AIU_ACODEC_CTRL 0>;
			};
		};

		dai-link-2 {
			sound-dai = <&aiu AIU_HDMI_CTRL 1>;
		};

		dai-link-3 {
			sound-dai = <&aiu AIU_ACODEC_CTRL 1>;
		};
	};
};

/* 视频：VDAC 输出到 AV 孔 */
&cvbs_vdac_port {
	cvbs_vdac_out: endpoint {
		remote-endpoint = <&cvbs_connector_in>;
	};
};

/* 开启音频硬件模块 */
&aiu {
	status = "okay";
};

&acodec {
	status = "okay";
};

/* 网络与存储修正 */
&internal_phy {
	max-speed = <100>;
};

&ethmac {
	status = "okay";
};

&mali {
	interrupts = <0 160 4>, <0 161 4>, <0 162 4>, <0 163 4>,
		     <0 164 4>, <0 165 4>, <0 166 4>, <0 167 4>;
	interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
};

&sd_emmc_c {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
};
