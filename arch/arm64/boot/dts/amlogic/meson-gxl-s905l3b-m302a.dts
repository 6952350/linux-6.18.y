/dts-v1/;

#include "meson-gxl-s905w-p281.dts"

/* 手动定义 ID，确保不依赖头文件也能起效 */
#define CPU_I2S_FIFO 1
#define CPU_I2S_ENCODER 1

/ {
	compatible = "amlogic,m302a", "amlogic,s905w", "amlogic,meson-gxl";
	model = "Amlogic Meson GXL (S905L3b) MBH-M302A Box";

	/* 1. 重新定义 sound 节点，覆盖 p23x-q20x.dtsi 中的默认配置 */
	sound {
		compatible = "amlogic,gx-sound-card";
		model = "M302A-AUDIO";
		status = "okay";

		/* 这里的路由非常关键：HDMI 和 AV (ACODEC) 必须并列 */
		audio-routing =
			"AU2 INL", "ACODEC LOLN",
			"AU2 INR", "ACODEC LORN",
			"HDMI INL", "HDMI",
			"HDMI INR", "HDMI";

		assigned-clocks = <&clkc 1>, <&clkc 2>, <&clkc 3>;
		assigned-clock-parents = <0>, <0>, <0>;
		assigned-clock-rates = <294912000>, <270950400>, <393216000>;

		/* Link 0: CPU I2S FIFO */
		dai-link-0 {
			sound-dai = <&aiu 0 1>; // AIU_CPU, CPU_I2S_FIFO
		};

		/* Link 1: 核心链路，同时把声音发给 HDMI 和 AV (ACODEC) */
		dai-link-1 {
			sound-dai = <&aiu 0 1>; // AIU_CPU, CPU_I2S_ENCODER
			dai-format = "i2s";
			mclk-fs = <256>;

			codec-0 {
				sound-dai = <&aiu 1 0>; // AIU_HDMI_CTRL, index 0
			};

			codec-1 {
				sound-dai = <&aiu 2 0>; // AIU_ACODEC_CTRL, index 0
			};
		};

		/* Link 2 & 3: 控制器 */
		dai-link-2 {
			sound-dai = <&aiu 1 1>; // AIU_HDMI_CTRL, index 1
		};

		dai-link-3 {
			sound-dai = <&aiu 2 1>; // AIU_ACODEC_CTRL, index 1
		};
	};

	/* CVBS 视频连接器 */
	cvbs-connector {
		compatible = "composite-video-connector";
		port {
			cvbs_connector_in: endpoint {
				remote-endpoint = <&cvbs_vdac_out>;
			};
		};
	};
};

/* 2. 视频通路连接 */
&cvbs_vdac_port {
	cvbs_vdac_out: endpoint {
		remote-endpoint = <&cvbs_connector_in>;
	};
};

/* 3. 启用硬件模块 */
&aiu {
	status = "okay";
};

&acodec {
	status = "okay";
};

/* 4. GPU/网络/存储修正 (保持你的原始需求) */
&mali {
	interrupts = <0 160 4>, <0 161 4>, <0 162 4>, <0 163 4>,
		     <0 164 4>, <0 165 4>, <0 166 4>, <0 167 4>;
	interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
};

&internal_phy {
	max-speed = <100>;
};

&ethmac {
	status = "okay";
};

&sd_emmc_c {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
};
