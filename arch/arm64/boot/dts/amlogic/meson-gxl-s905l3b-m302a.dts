/dts-v1/;

/* 包含原始 P281 定义，它已经处理好了 HDMI 和基础音频 */
#include "meson-gxl-s905w-p281.dts"

/ {
	compatible = "amlogic,m302a", "amlogic,s905w", "amlogic,meson-gxl";
	model = "Amlogic Meson GXL (S905L3b) MBH-M302A Box";

	/* 修正内存 */
	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	/* CVBS 视频连接器 */
	cvbs-connector {
		compatible = "composite-video-connector";
		port {
			cvbs_connector_in: endpoint {
				remote-endpoint = <&cvbs_vdac_out>;
			};
		};
	};
};

/* 1. 视频输出连接：只连接引脚，不修改 VDAC 状态以免报错 */
&cvbs_vdac_port {
	cvbs_vdac_out: endpoint {
		remote-endpoint = <&cvbs_connector_in>;
	};
};

/* 2. 音频修正：通过绝对路径向现有声卡追加 AV(ACODEC) 路由 */
/* 这样不会破坏 HDMI，也不会让声卡消失 */
&{/sound} {
	audio-routing =
		"AU2 INL", "ACODEC LOLN",
		"AU2 INR", "ACODEC LORN",
		"HDMI INL", "HDMI",
		"HDMI INR", "HDMI";
};

/* 3. 在现有的 I2S 链路中注入模拟输出 */
&{/sound/dai-link-1} {
	codec-1 {
		sound-dai = <&aiu 2 0>; /* 2 = AIU_ACODEC_CTRL, 0 = index */
	};
};

/* 4. 确保硬件模块开启 */
&aiu {
	status = "okay";
};

&acodec {
	status = "okay";
};

/* 5. GPU 中断修正 (S905L3b 专用) */
&mali {
	interrupts = <0 160 4>, <0 161 4>, <0 162 4>, <0 163 4>,
		     <0 164 4>, <0 165 4>, <0 166 4>, <0 167 4>;
	interrupt-names = "gp", "gpmmu", "pp", "pmu", "pp0", "ppmmu0", "pp1", "ppmmu1";
};

/* 6. 其他硬件限制 */
&internal_phy {
	max-speed = <100>;
};

&ethmac {
	status = "okay";
};

&sd_emmc_c {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	max-frequency = <200000000>;
};
